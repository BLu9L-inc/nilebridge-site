<script>
// ── NAV ──
const nav=document.getElementById('nav');
window.addEventListener('scroll',()=>nav.classList.toggle('scrolled',window.scrollY>50));

// ── MOBILE DRAWER ──
function toggleMobile(){
  const d=document.getElementById('mobile-drawer');
  const h=document.getElementById('hamburger');
  d.classList.toggle('open');
  h.classList.toggle('open');
  document.body.style.overflow=d.classList.contains('open')?'hidden':'';
}
function closeMobile(){
  document.getElementById('mobile-drawer').classList.remove('open');
  document.getElementById('hamburger').classList.remove('open');
  document.body.style.overflow='';
}

// ── COUNTDOWN (with post-event fallback) ──
function tick(){
  const launch=new Date('2026-06-28T09:00:00');
  const now=new Date();
  const d=launch-now;
  const row=document.getElementById('cd-row');
  const post=document.getElementById('cd-post');
  if(d<=0){
    if(row)row.style.display='none';
    if(post){post.style.display='block';}
    return;
  }
  const pad=n=>String(n).padStart(2,'0');
  document.getElementById('cd-d').textContent=pad(Math.floor(d/86400000));
  document.getElementById('cd-h').textContent=pad(Math.floor(d/3600000)%24);
  document.getElementById('cd-m').textContent=pad(Math.floor(d/60000)%60);
  document.getElementById('cd-s').textContent=pad(Math.floor(d/1000)%60);
}
tick();setInterval(tick,1000);

// ── REVEAL ──
const obs=new IntersectionObserver(entries=>entries.forEach(e=>{
  if(e.isIntersecting){e.target.classList.add('in');obs.unobserve(e.target);}
}),{threshold:.08});
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));

// ── SMOOTH SCROLL ──
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{
    const t=document.querySelector(a.getAttribute('href'));
    if(t){e.preventDefault();t.scrollIntoView({behavior:'smooth',block:'start'});}
  });
});

// ── LANGUAGE ──
function setLang(lang){
  const html=document.getElementById('html-root');
  html.lang=lang;
  html.dir=lang==='ar'?'rtl':'ltr';
  ['btn-en','md-btn-en'].forEach(id=>{const el=document.getElementById(id);if(el)el.classList.toggle('active',lang==='en');});
  ['btn-ar','md-btn-ar'].forEach(id=>{const el=document.getElementById(id);if(el)el.classList.toggle('active',lang==='ar');});
  document.title=lang==='ar'?'بلو9إل | إيراس® مصر — منصة ذكاء وأمن المدارس':'Blu9L | IRAS® Egypt — AI School Intelligence & Safety Platform';
  document.querySelectorAll('[data-en]').forEach(el=>{
    const txt=el.getAttribute('data-'+lang);
    if(txt)el.innerHTML=txt;
  });
  document.querySelectorAll('[data-en-placeholder]').forEach(el=>{
    el.placeholder=el.getAttribute('data-'+lang+'-placeholder')||el.placeholder;
  });
  document.querySelectorAll('select option[data-en]').forEach(opt=>{
    const txt=opt.getAttribute('data-'+lang);
    if(txt)opt.textContent=txt;
  });
  // Load Arabic fonts on demand
  if(lang==='ar'&&!document.getElementById('ar-fonts')){
    const link=document.createElement('link');
    link.id='ar-fonts';
    link.rel='stylesheet';
    link.href='https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap';
    document.head.appendChild(link);
  }
  ['form-btn','event-btn'].forEach(id=>{
    const btn=document.getElementById(id);
    if(btn&&!btn.disabled){
      btn.textContent=lang==='ar'?(id==='event-btn'?'طلب الدعوة':'إرسال الرسالة'):(id==='event-btn'?'Request Invitation':'Send Message');
    }
  });
  try{localStorage.setItem('blu9l_lang',lang);}catch(e){}
  // Force layout recalculation after direction change
  document.body.style.display='none';
  void document.body.offsetHeight;
  document.body.style.display='';
}
try{const s=localStorage.getItem('blu9l_lang');if(s&&s!=='en')setLang(s);}catch(e){}

// ── CONTACT FORM ──
async function handleContactSubmit(e){
  e.preventDefault();
  const btn=document.getElementById('form-btn');
  const form=document.getElementById('contact-form');
  const lang=document.getElementById('html-root').lang;
  const orig=btn.textContent;
  btn.textContent=lang==='ar'?'جارٍ الإرسال...':'Sending...';
  btn.disabled=true;
  try{
    const res=await fetch('https://api.web3forms.com/submit',{method:'POST',body:new FormData(form)});
    const j=await res.json();
    if(j.success){
      btn.innerHTML=lang==='ar'?'&#10003; تم الإرسال':'&#10003; Sent!';
      btn.style.background='#0A5C2A';
      form.reset();
      setTimeout(()=>{btn.textContent=orig;btn.style.background='';btn.disabled=false;},4000);
    }else{throw new Error();}
  }catch{
    btn.textContent=lang==='ar'?'خطأ — راسلنا مباشرة':'Error — Email us directly';
    btn.style.background='#7B1C1C';
    setTimeout(()=>{btn.textContent=orig;btn.style.background='';btn.disabled=false;},4000);
  }
}

// ── EVENT FORM ──
async function handleEventSubmit(e){
  e.preventDefault();
  const btn=document.getElementById('event-btn');
  const form=document.getElementById('event-form');
  const lang=document.getElementById('html-root').lang;
  const orig=btn.textContent;
  btn.textContent=lang==='ar'?'جارٍ الإرسال...':'Sending...';
  btn.disabled=true;
  try{
    const res=await fetch('https://api.web3forms.com/submit',{method:'POST',body:new FormData(form)});
    const j=await res.json();
    if(j.success){
      btn.innerHTML=lang==='ar'?'&#10003; تلقّينا طلبك!':'&#10003; Request Received!';
      btn.style.background='#0A5C2A';
      form.reset();
      setTimeout(()=>{btn.textContent=orig;btn.style.background='';btn.disabled=false;},5000);
    }else{throw new Error();}
  }catch{
    btn.textContent=lang==='ar'?'خطأ — واتساب للتسجيل السريع':'Error — WhatsApp to register fast';
    btn.style.background='#7B1C1C';
    setTimeout(()=>{btn.textContent=orig;btn.style.background='';btn.disabled=false;},4000);
  }
}
